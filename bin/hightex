#!/usr/bin/env bash
set -euo pipefail

CLI_VERSION="0.0.2"
CLI_SERVER="${HIGHTEX_SERVER:-https://hightex.jefyokta.my.id}"
OWNER="jefyokta"
REPO="hightex-desktop"
API="https://api.github.com/repos/${OWNER}/${REPO}/releases/latest"

if [[ -t 1 ]] && [[ -z "${NO_COLOR:-}" ]]; then
  C_RESET=$'\033[0m'
  C_BOLD=$'\033[1m'
  C_DIM=$'\033[2m'
  C_RED=$'\033[31m'
  C_GREEN=$'\033[32m'
  C_YELLOW=$'\033[33m'
  C_CYAN=$'\033[36m'
else
  C_RESET='' C_BOLD='' C_DIM='' C_RED='' C_GREEN='' C_YELLOW='' C_CYAN=''
fi

_err() { printf '%s%s%s\n' "$C_RED" "$*" "$C_RESET" >&2; }
_warn() { printf '%s%s%s\n' "$C_YELLOW" "$*" "$C_RESET" >&2; }
_ok() { printf '%s%s%s\n' "$C_GREEN" "$*" "$C_RESET"; }
_info() { printf '%s%s%s\n' "$C_DIM" "$*" "$C_RESET"; }

_executeable() {
  if [[ "$(uname)" == "Darwin" ]]; then
    echo "/Applications/HighTex.app/Contents/MacOS/HighTex"
  else
    local libexec
    libexec="$(dirname "$(dirname "$(realpath "$0")")")/libexec"
    echo "${libexec}/HighTex.AppImage"
  fi
}

_installed_version() {
  if [[ "$(uname)" == "Darwin" ]]; then
    local plist="/Applications/HighTex.app/Contents/Info.plist"
    if [[ -f "$plist" ]]; then
      /usr/libexec/PlistBuddy -c "Print CFBundleShortVersionString" "$plist" 2>/dev/null || echo "unknown"
    else
      echo "unknown"
    fi
  else
    local marker
    marker="$(dirname "$(dirname "$(realpath "$0")")")/libexec/.hightex-version"
    [[ -f "$marker" ]] && cat "$marker" || echo "unknown"
  fi
}

_latest_version() {
  curl -fsSL "$API" | grep '"tag_name"' | sed 's/.*"tag_name": *"v\([^"]*\)".*/\1/'
}

_version_lt() {
  [[ "$1" != "$2" ]] && [[ "$(printf '%s\n%s' "$1" "$2" | sort -V | head -1)" == "$1" ]]
}

_list_documents() {
  local exe="$1"
  "$exe" documents
}

_document_exists() {
  local exe="$1" docId="$2"
  local id title
  while IFS=$'\t' read -r id title; do
    [[ "$id" == "$docId" ]] && return 0
  done < <(_list_documents "$exe")
  return 1
}

MENU_OPTIONS=()
MENU_IDS=()

_arrow_select() {
  local count=${#MENU_OPTIONS[@]}
  local selected=0
  local key rest first=1 i

  tput civis >&2 2>/dev/null || true
  trap 'tput cnorm >&2 2>/dev/null || true' RETURN

  while true; do
    if [[ $first -eq 0 ]]; then
      printf '\033[%dA' "$count" >&2
    fi
    first=0

    for i in "${!MENU_OPTIONS[@]}"; do
      printf '\033[2K' >&2
      if [[ $i -eq $selected ]]; then
        printf '%s%s→ %s%s\n' "$C_CYAN" "$C_BOLD" "${MENU_OPTIONS[$i]}" "$C_RESET" >&2
      else
        printf '  %s\n' "${MENU_OPTIONS[$i]}" >&2
      fi
    done

    IFS= read -rsn1 key
    if [[ $key == $'\x1b' ]]; then
      IFS= read -rsn2 rest
      case "$rest" in
        '[A') (( selected = (selected - 1 + count) % count )) ;;
        '[B') (( selected = (selected + 1) % count )) ;;
      esac
    elif [[ $key == "k" ]]; then
      (( selected = (selected - 1 + count) % count ))
    elif [[ $key == "j" ]]; then
      (( selected = (selected + 1) % count ))
    elif [[ -z $key ]]; then
      break
    fi
  done

  echo "$selected"
}

_select_document() {
  local exe="$1"
  local output
  output="$(_list_documents "$exe")"

  [[ -n "$output" ]] || {
    _err "error: no documents found"
    exit 1
  }

  MENU_OPTIONS=()
  MENU_IDS=()
  local id title
  while IFS=$'\t' read -r id title; do
    [[ -z "$id" ]] && continue
    MENU_IDS+=("$id")
    MENU_OPTIONS+=("$title $C_DIM $id $C_RESET")
  done <<< "$output"

  [[ ${#MENU_IDS[@]} -gt 0 ]] || {
    _err "error: no documents found"
    exit 1
  }

  local idx
  if [[ -t 0 ]]; then
    idx="$(_arrow_select)"
  else
    PS3="Select document to compile: "
    local choice
    select choice in "${MENU_OPTIONS[@]}"; do
      [[ -n "$choice" ]] && { idx=$((REPLY-1)); break; }
    done
  fi

  echo "${MENU_IDS[$idx]}"
}

cmd_open() {
  if [[ "$(uname)" == "Darwin" ]]; then
    open -a "/Applications/HighTex.app"
  else
    local libexec appimage
    libexec="$(dirname "$(dirname "$(realpath "$0")")")/libexec"
    appimage="${libexec}/HighTex.AppImage"

    [[ -x "$appimage" ]] || {
      _err "error: HighTex.AppImage not found"
      exit 1
    }

    nohup "$appimage" >/dev/null 2>&1 &
    disown
  fi
}

normalize_url() {
  local url="$1"
  printf '%s' "$url" | sed 's#\\/#/#g'
}

cmd_update() {
  echo "Checking HighTex updates..."

  local installed latest
  installed="$(_installed_version)"
  latest="$(_latest_version)"

  if [[ -z "$latest" ]]; then
    _err "error: unable to check latest version"
    exit 1
  fi

  printf '%sInstalled%s : %s\n' "$C_DIM" "$C_RESET" "$installed"
  printf '%sLatest%s    : %s\n' "$C_DIM" "$C_RESET" "$latest"

  if [[ "$installed" == "unknown" ]]; then
    _warn "warning: HighTex installation not detected"
    exit 1
  fi

  if _version_lt "$installed" "$latest"; then
    _warn "A new version is available. Run: brew upgrade --cask hightex"
    read -r -p "Upgrade now? [y/n] " update_confirm
    case "$update_confirm" in
      y|Y|yes|YES|Yes) ;;
      *) echo "Aborted."; exit 0 ;;
    esac
    if [[ "$(uname)" == "Darwin" ]]; then
      brew upgrade --cask hightex
    else
      brew upgrade higtex
    fi
      
  else
    _ok "HighTex is already up to date."
  fi
}

cmd_upgrade() {
  local server="$CLI_SERVER"

  for arg in "$@"; do
    case "$arg" in
      -m=*|--mirror=*) server="${arg#*=}" ;;
    esac
  done

  server="${server%/}"

  if [[ "$server" != "$CLI_SERVER" ]]; then
    _warn "warning: using custom mirror $server"
    read -r -p "Continue with this mirror? [y/N] " mirror_confirm
    case "$mirror_confirm" in
      y|Y|yes|YES|Yes) ;;
      *) echo "Aborted."; exit 0 ;;
    esac
  fi

  echo "Checking CLI updates..."
  printf '%sMirror%s : %s\n' "$C_DIM" "$C_RESET" "$server"

  local json latest download

  json="$(curl -fsSL "$server/cli/latest")" || {
    _err "error: unable to contact $server"
    exit 1
  }

  latest="$(printf '%s' "$json" | grep '"version"' | sed 's/.*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/')"

  download="$(
    printf '%s' "$json" |
    sed -n 's/.*"download"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p'
  )";

  download="$(normalize_url "$download")"

  [[ -n "$latest" && -n "$download" ]] || {
    _err "error: invalid server response"
    exit 1
  }

  printf '%sInstalled%s : %s\n' "$C_DIM" "$C_RESET" "$CLI_VERSION"
  printf '%sLatest%s    : %s\n' "$C_DIM" "$C_RESET" "$latest"

  if ! _version_lt "$CLI_VERSION" "$latest"; then
    _ok "CLI is already up to date."
    exit 0
  fi

  read -r -p "Upgrade CLI now? [y/N] " confirm
  case "$confirm" in
    y|Y|yes|YES|Yes) ;;
    *) echo "Aborted."; exit 0 ;;
  esac

  local self tmp final

  self="$(realpath "$0")"
  tmp="$(mktemp)"
  final="${self}.new"

  cleanup() {
    rm -f "$tmp" "$final" 2>/dev/null || true
  }
  trap cleanup EXIT

  echo "Downloading..."
  printf 'Download: %s\n' "$download"

  curl -fL "$download" -o "$tmp" || {
    _err "error: download failed"
    exit 1
  }

  [[ -s "$tmp" ]] || {
    _err "error: downloaded file is empty"
    exit 1
  }

  chmod +x "$tmp"

  mv "$tmp" "$final"
  mv "$final" "$self"

  chmod +x "$self"

  echo
  _ok "HighTex CLI upgraded to $latest"
}

cmd_version() {
  echo "HighTex $(_installed_version)"
  echo "Hightex-cli $CLI_VERSION"
}

cmd_documents() {
  local exe
  exe="$(_executeable)"

  [[ -x "$exe" ]] || {
    _err "error: HighTex executable not found at $exe"
    exit 1
  }

  "$exe" documents "$@"
}

cmd_compile() {
  local docId="${1:-}"
  local saveTo="${2:-}"

  local exe
  exe="$(_executeable)"

  [[ -x "$exe" ]] || {
    _err "error: HighTex executable not found at $exe"
    exit 1
  }

  if [[ -z "$docId" ]]; then
    docId="$(_select_document "$exe")"
  fi

  _document_exists "$exe" "$docId" || {
    _err "error: document '$docId' not found"
    exit 1
  }

  if [[ -n "$saveTo" ]]; then
    "$exe" compile "$docId" "$saveTo"
  else
    "$exe" compile "$docId"
  fi
}

cmd_help() {
  cat <<EOF
hightex - CLI

Usage:
  hightex open                      Open Hightex Desktop
  hightex update                    Checking Hightex Desktop update
  hightex upgrade                   Upgrading hightex-cli it self
  hightex version                   Print version of Hightex Desktop and hightex-cli
  hightex documents                 Get List of hightex documents
  hightex compile [docId] [saveTo]  Compiling hightex document into pdf
EOF
}

case "$(_installed_version)" in
    unknown) _warn "Warning Application is Missing!";;
esac

case "${1:-open}" in
  open) cmd_open ;;
  update) cmd_update ;;
  version|-v|--version) cmd_version ;;
  help|-h|--help) cmd_help ;;
  upgrade)
    shift
    cmd_upgrade "$@"
    ;;
  documents)
    shift
    cmd_documents "$@"
    ;;
  compile)
    shift
    cmd_compile "$@"
    ;;
  *)
    _err "error: unknown command '$1'"
    exit 1
    ;;
esac